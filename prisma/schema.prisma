generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" 
  url      = env("DATABASE_URL")
}

model CampaignSession {
  id               String   @id @default(cuid())
  userId           String?  
  budgetPayload    String   
  projectedRevenue Float    
  roi              Float    
  createdAt        DateTime @default(now())
}